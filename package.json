{
  "name": "org-intel-mcp",
  "version": "2.0.0",
  "description": "MCP Server that researches company organizational structure and decision-makers from public web data",
  "type": "module",
  "bin": {
    "org-intel-mcp": "./dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "web": "node dist/web/web-server.js",
    "add-user": "node scripts/add-user.js",
    "dev": "tsc --watch",
    "test": "node dist/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.2.0",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "jsdom": "^29.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.60.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.12.4",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "mcp",
    "claude",
    "org-chart",
    "company-research"
